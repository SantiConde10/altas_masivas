{
  "name": "gaia-alta-masiva",
  "version": "1.0.7",
  "description": "Aplicación de escritorio para la carga masiva de artículos en GAIA",
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox --disable-gpu",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac --x64"
  },
  "author": "Santi Conde",
  "license": "ISC",
  "dependencies": {
    "electron-updater": "^6.1.8"
  },
  "devDependencies": {
    "electron": "^41.7.1",
    "electron-builder": "^26.8.1",
    "playwright-core": "^1.60.0"
  },
  "build": {
    "appId": "com.gaia.altamasiva",
    "productName": "GAIA Automatizaciones",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "../dist",
        "to": "python_bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "assets/icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "SantiConde10",
        "repo": "altas_masivas",
        "releaseType": "release"
      }
    ]
  }
}
