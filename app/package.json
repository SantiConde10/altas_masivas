{
  "name": "gaia-alta-masiva",
  "version": "1.0.13",
  "description": "Aplicación de escritorio para la carga masiva de artículos en GAIA",
  "main": "main.js",
  "scripts": {
    "start": "electron . --disable-gpu",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac --x64"
  },
  "author": "Santi Conde",
  "license": "ISC",
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "playwright-core": "^1.60.0"
  },
  "build": {
    "appId": "com.gaia.altamasiva",
    "productName": "GAIA Automatizaciones",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "../dist",
        "to": "python_bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.png",
      "sign": true,
      "gatekeeperAssess": true
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "SantiConde10",
        "repo": "altas_masivas",
        "releaseType": "release"
      }
    ]
  }
}
